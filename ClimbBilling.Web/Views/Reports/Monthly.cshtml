@model ClimbBilling.Web.Models.ViewModels.MonthlyReportViewModel
@{
    ViewData["Title"] = $"Monthly Report — {Model.MonthName}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"><i class="bi bi-bar-chart me-2"></i>Monthly Report</h2>

    @* Month/Year picker *@
    <form method="get" class="d-flex gap-2 align-items-center">
        <select name="month" class="form-select form-select-sm" style="width:140px;">
            @for (int m = 1; m <= 12; m++)
            {
                <option value="@m" selected="@(Model.SelectedMonth == m)">
                    @(new DateTime(2000, m, 1).ToString("MMMM"))
                </option>
            }
        </select>
        <select name="year" class="form-select form-select-sm" style="width:90px;">
            @foreach (var y in Model.AvailableYears)
            {
                <option value="@y" selected="@(Model.SelectedYear == y)">@y</option>
            }
        </select>
        <button type="submit" class="btn btn-sm btn-outline-secondary">Go</button>
    </form>
</div>

@* Navigation arrows *@
<div class="d-flex justify-content-between mb-4">
    @{
        var prev = new DateTime(Model.Year, Model.Month, 1).AddMonths(-1);
        var next = new DateTime(Model.Year, Model.Month, 1).AddMonths(1);
        bool canGoNext = next <= DateTime.Today;
    }
    <a asp-action="Monthly" asp-route-year="@prev.Year" asp-route-month="@prev.Month"
       class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-chevron-left me-1"></i>@prev.ToString("MMMM yyyy")
    </a>
    @if (canGoNext)
    {
        <a asp-action="Monthly" asp-route-year="@next.Year" asp-route-month="@next.Month"
           class="btn btn-sm btn-outline-secondary">
            @next.ToString("MMMM yyyy")<i class="bi bi-chevron-right ms-1"></i>
        </a>
    }
</div>

@* Summary cards *@
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Invoiced</div>
                <div class="h4">$@Model.TotalInvoiced.ToString("N2")</div>
                <div class="text-muted small">@Model.InvoiceCount invoice(s)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Collected</div>
                <div class="h4 text-success">$@Model.TotalCollected.ToString("N2")</div>
                <div class="text-muted small">@Model.PaidInvoiceCount paid</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Outstanding</div>
                <div class="h4 @(Model.TotalOutstanding > 0 ? "text-danger" : "text-muted")">
                    $@Model.TotalOutstanding.ToString("N2")
                </div>
                <div class="text-muted small">@Model.StudentCount student(s)</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm text-center h-100">
            <div class="card-body">
                <div class="text-muted small">Platform Fees</div>
                <div class="h4 text-secondary">$@Model.PlatformFeesCharged.ToString("N2")</div>
                <div class="text-muted small">deducted from payouts</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    @* Revenue breakdown *@
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="mb-0">Revenue by Type</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span>Flight Instruction</span>
                    <strong>$@Model.InstructionRevenue.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span>Aircraft / Sim Rental</span>
                    <strong>$@Model.AircraftRentalRevenue.ToString("N2")</strong>
                </div>
                @if (Model.OtherRevenue != 0)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>Other</span>
                        <strong>$@Model.OtherRevenue.ToString("N2")</strong>
                    </div>
                }
                <hr />
                <div class="d-flex justify-content-between fw-bold">
                    <span>Total</span>
                    <span>$@Model.TotalInvoiced.ToString("N2")</span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm mt-3">
            <div class="card-header bg-white">
                <h6 class="mb-0">Collected by Method</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span><i class="bi bi-credit-card me-2"></i>Card (Stripe)</span>
                    <strong>$@Model.CollectedByCard.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span><i class="bi bi-bank me-2"></i>ACH Bank Transfer</span>
                    <strong>$@Model.CollectedByACH.ToString("N2")</strong>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span><i class="bi bi-cash me-2"></i>Cash / Venmo / Zelle</span>
                    <strong>$@Model.CollectedByManual.ToString("N2")</strong>
                </div>
            </div>
        </div>
    </div>

    @* Invoice list *@
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between">
                <h6 class="mb-0">Invoices — @Model.MonthName</h6>
                <small class="text-muted">For bookkeeping</small>
            </div>
            <div class="card-body p-0">
                @if (!Model.Invoices.Any())
                {
                    <div class="text-center py-4 text-muted small">No invoices in this period.</div>
                }
                else
                {
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Invoice #</th>
                                <th>Student</th>
                                <th>Date</th>
                                <th class="text-end">Total</th>
                                <th class="text-end">Paid</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Invoices)
                            {
                                <tr>
                                    <td class="fw-semibold small">@row.InvoiceNumber</td>
                                    <td class="small">@row.StudentName</td>
                                    <td class="small">@row.InvoiceDate.ToLocalTime().ToString("M/d")</td>
                                    <td class="text-end small">$@row.TotalAmount.ToString("N2")</td>
                                    <td class="text-end small @(row.AmountPaid > 0 ? "text-success" : "")">
                                        $@row.AmountPaid.ToString("N2")
                                    </td>
                                    <td><span class="badge @StatusClass(row.Status) small">@row.Status</span></td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="border-top">
                            <tr>
                                <td colspan="3" class="text-end fw-bold small">Totals</td>
                                <td class="text-end fw-bold small">$@Model.TotalInvoiced.ToString("N2")</td>
                                <td class="text-end fw-bold text-success small">$@Model.TotalCollected.ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

@functions {
    string StatusClass(string s) => s switch {
        "Paid" => "bg-success",
        "PartiallyPaid" => "bg-info text-dark",
        "Sent" => "bg-primary",
        "Draft" => "bg-secondary",
        _ => "bg-secondary"
    };
}
