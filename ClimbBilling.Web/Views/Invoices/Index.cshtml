@using ClimbBilling.Web.Models.Entities
@model ClimbBilling.Web.Models.ViewModels.InvoiceListViewModel
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"><i class="bi bi-receipt me-2"></i>Invoices</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Invoice
    </a>
</div>

@* Filters *@
<div class="card shadow-sm mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small text-muted mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (var s in new[] { "Draft", "Sent", "PartiallyPaid", "Paid", "Void" })
                    {
                        <option value="@s" selected="@(Model.StatusFilter == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <label class="form-label small text-muted mb-1">Year</label>
                <select name="year" class="form-select form-select-sm">
                    <option value="">All Years</option>
                    @foreach (var y in Model.AvailableYears)
                    {
                        <option value="@y" selected="@(Model.YearFilter == y)">@y</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-outline-secondary">Filter</button>
                <a asp-action="Index" class="btn btn-sm btn-link">Clear</a>
            </div>
        </form>
    </div>
</div>

@if (!Model.Invoices.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-receipt fs-1 d-block mb-2"></i>
            No invoices found. <a asp-action="Create">Create an invoice</a>.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Student</th>
                            <th>Date</th>
                            <th>Due</th>
                            <th class="text-end">Total</th>
                            <th class="text-end">Balance</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var inv in Model.Invoices)
                        {
                            <tr class="@(inv.IsOverdue ? "table-danger" : "")">
                                <td class="fw-semibold">@inv.InvoiceNumber</td>
                                <td>@inv.StudentName</td>
                                <td>@inv.InvoiceDate.ToLocalTime().ToString("M/d/yyyy")</td>
                                <td>
                                    @(inv.DueDate.HasValue ? inv.DueDate.Value.ToLocalTime().ToString("M/d/yyyy") : "—")
                                    @if (inv.IsOverdue)
                                    {
                                        <span class="badge bg-danger ms-1">Overdue</span>
                                    }
                                </td>
                                <td class="text-end">$@inv.TotalAmount.ToString("N2")</td>
                                <td class="text-end @(inv.BalanceDue > 0 ? "text-danger fw-semibold" : "text-success")">
                                    $@inv.BalanceDue.ToString("N2")
                                </td>
                                <td><span class="badge @StatusClass(inv.Status)">@inv.Status</span></td>
                                <td>
                                    <a asp-action="Detail" asp-route-id="@inv.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@functions {
    string StatusClass(string s) => s switch {
        "Paid" => "bg-success",
        "PartiallyPaid" => "bg-info text-dark",
        "Sent" => "bg-primary",
        "Draft" => "bg-secondary",
        "Void" => "bg-dark",
        _ => "bg-secondary"
    };
}
