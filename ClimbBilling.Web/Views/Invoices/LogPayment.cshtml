@using ClimbBilling.Web.Models.Entities
@model ClimbBilling.Web.Models.ViewModels.LogManualPaymentViewModel
@{
    ViewData["Title"] = "Log Payment";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-cash me-2"></i>Log Manual Payment</h5>
                <div class="text-muted small">Invoice @Model.InvoiceNumber &bull; Balance due: $@Model.BalanceDue.ToString("N2")</div>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Use this form to record a payment received outside of Stripe — cash, check, Venmo, Zelle, etc.
                </p>
                <form asp-action="LogPayment" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input asp-for="InvoiceId" type="hidden" />
                    <input asp-for="InvoiceNumber" type="hidden" />

                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label fw-semibold">Amount Received ($)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Amount" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Method" class="form-label fw-semibold">Payment Method</label>
                        <select asp-for="Method" class="form-select"
                                asp-items="Html.GetEnumSelectList<PaymentMethod>()"></select>
                        <span asp-validation-for="Method" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PaymentDate" class="form-label fw-semibold">Payment Date</label>
                        <input asp-for="PaymentDate" class="form-control" type="date" />
                        <span asp-validation-for="PaymentDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold">Notes <small class="text-muted">(optional)</small></label>
                        <input asp-for="Notes" class="form-control" placeholder="Confirmation number, memo, etc." />
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-lg me-1"></i>Record Payment
                        </button>
                        <a asp-action="Detail" asp-route-id="@Model.InvoiceId" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
