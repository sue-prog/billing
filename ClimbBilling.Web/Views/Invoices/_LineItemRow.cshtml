@using ClimbBilling.Web.Models.Entities
@model (ClimbBilling.Web.Models.ViewModels.LineItemInputModel item, int index)

@{
    var item = Model.item;
    var i = Model.index;
}

<div class="line-item-row border rounded p-3 mb-3">
    <div class="row g-2 mb-2">
        <div class="col-12">
            <input name="LineItems[@i].Description" class="form-control form-control-sm"
                   placeholder="Description" value="@item.Description" required />
        </div>
    </div>
    <div class="row g-2 align-items-center">
        <div class="col-3">
            <label class="form-label form-label-sm text-muted mb-0">Hours</label>
            <input name="LineItems[@i].Quantity" type="number" step="0.1" min="0.1"
                   class="form-control form-control-sm qty-input"
                   value="@item.Quantity" onchange="updateTotal()" required />
        </div>
        <div class="col-4">
            <label class="form-label form-label-sm text-muted mb-0">Rate ($/hr)</label>
            <div class="input-group input-group-sm">
                <span class="input-group-text">$</span>
                <input name="LineItems[@i].UnitPrice" type="number" step="0.01" min="0.01"
                       class="form-control price-input"
                       value="@item.UnitPrice" onchange="updateTotal()" required />
            </div>
        </div>
        <div class="col-4">
            <label class="form-label form-label-sm text-muted mb-0">Service Date</label>
            <input name="LineItems[@i].ServiceDate" type="date" class="form-control form-control-sm"
                   value="@item.ServiceDate?.ToString("yyyy-MM-dd")" />
        </div>
        <div class="col-1 d-flex align-items-end justify-content-end">
            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeLineItem(this)">
                <i class="bi bi-trash"></i>
            </button>
        </div>
    </div>
    <input type="hidden" name="LineItems[@i].Type" value="@item.Type" />
</div>
