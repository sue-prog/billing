@using ClimbBilling.Web.Models.Entities
@model List<Rate>
@{
    ViewData["Title"] = "Rates";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"><i class="bi bi-tag me-2"></i>My Rates</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Rate
    </a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-tag fs-1 d-block mb-2"></i>
            No rates defined yet. <a asp-action="Create">Add your first rate</a>.
            <div class="mt-2 small">Example: "Dual Instruction — $65/hr", "Cessna 172 Rental — $120/hr"</div>
        </div>
    </div>
}
else
{
    @* Group by type *@
    @foreach (var group in Model.GroupBy(r => r.Type).OrderBy(g => g.Key))
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-white">
                <h6 class="mb-0 text-secondary">@group.Key.ToString().Replace("Rental", " Rental")</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Label</th>
                            <th class="text-end">Hourly Rate</th>
                            <th class="text-center">Active</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rate in group)
                        {
                            <tr>
                                <td>@rate.Label</td>
                                <td class="text-end fw-semibold">$@rate.HourlyRate.ToString("N2")</td>
                                <td class="text-center">
                                    @if (rate.IsActive)
                                    {
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-x-circle text-muted"></i>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@rate.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                    <form asp-action="Delete" asp-route-id="@rate.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this rate?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}
