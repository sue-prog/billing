@using ClimbBilling.Web.Models.Entities
@model RateEditModel

<div class="mb-3">
    <label asp-for="Type" class="form-label fw-semibold">Type</label>
    <select asp-for="Type" class="form-select"
            asp-items="Html.GetEnumSelectList<RateType>()"></select>
    <span asp-validation-for="Type" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="Label" class="form-label fw-semibold">Label</label>
    <input asp-for="Label" class="form-control" placeholder="e.g., Cessna 172 Rental, Dual Instruction" />
    <span asp-validation-for="Label" class="text-danger small"></span>
</div>
<div class="mb-3">
    <label asp-for="HourlyRate" class="form-label fw-semibold">Hourly Rate ($)</label>
    <div class="input-group">
        <span class="input-group-text">$</span>
        <input asp-for="HourlyRate" class="form-control" type="number" step="0.01" min="0.01" />
    </div>
    <span asp-validation-for="HourlyRate" class="text-danger small"></span>
</div>
<div class="mb-4">
    <div class="form-check">
        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
        <label asp-for="IsActive" class="form-check-label">Active (available when creating invoices)</label>
    </div>
</div>
