@model List<StudentListRow>
@{
    ViewData["Title"] = "Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 mb-0"><i class="bi bi-people me-2"></i>Students</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Student
    </a>
</div>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5 text-muted">
            <i class="bi bi-person-plus fs-1 d-block mb-2"></i>
            No students yet. <a asp-action="Create">Add your first student</a> to get started.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th class="text-center">Invoices</th>
                            <th class="text-end">Total Billed</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@s.Name</td>
                                <td><a href="mailto:@s.Email">@s.Email</a></td>
                                <td>@(s.Phone ?? "—")</td>
                                <td class="text-center">@s.InvoiceCount</td>
                                <td class="text-end">$@s.TotalBilled.ToString("N2")</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                    <form asp-action="Deactivate" asp-route-id="@s.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Remove this student?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
